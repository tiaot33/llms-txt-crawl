{
  "name": "llms-txt-crawl",
  "version": "1.0.0",
  "description": "Probe LLMS-friendly documents and recursively crawl linked markdown/text documents.",
  "type": "module",
  "license": "MIT",
  "author": "tiaot33",
  "repository": {
    "type": "git",
    "url": "https://github.com/tiaot33/llms-txt-crawl.git"
  },
  "keywords": [
    "llms",
    "llms-txt",
    "crawler",
    "markdown",
    "documentation"
  ],
  "bin": {
    "llms-txt-crawl": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node \"./dist/cli.js\"",
    "build": "tsc -p tsconfig.json && node --eval \"if (process.platform !== 'win32') require('node:fs').chmodSync('./dist/cli.js', 0o755)\"",
    "test": "node --test --experimental-strip-types \"./test/**/*.test.ts\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
